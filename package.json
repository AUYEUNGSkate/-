{
  "name": "game-hotspot-radar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:api": "tsx watch server/index.ts",
    "worker": "tsx server/worker.ts",
    "scan": "tsx server/scripts/run-scan.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "start": "node --import tsx server/index.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.1.17",
    "better-sqlite3": "^12.4.6",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.2",
    "lucide-react": "^0.562.0",
    "motion": "^12.40.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
